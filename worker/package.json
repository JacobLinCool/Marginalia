{
  "name": "arxiv-rq-claims-worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "test": "node --test --experimental-strip-types \"src/**/*.test.ts\"",
    "cf-typegen": "wrangler types",
    "migrate:local": "wrangler d1 migrations apply arxiv_rq_claims --local",
    "migrate:remote": "wrangler d1 migrations apply arxiv_rq_claims --remote"
  },
  "dependencies": {
    "fast-xml-parser": "^4.5.0",
    "openai": "^4.73.0",
    "takumi-js": "^1.5.1",
    "unpdf": "^0.12.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20251101.0",
    "typescript": "^5.6.0",
    "wrangler": "^4.0.0"
  }
}
